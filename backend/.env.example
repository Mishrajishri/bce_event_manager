# BCE Event Manager - Backend Environment Variables
# Copy this file to .env and fill in the values

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/event_manager?retryWrites=true&w=majority

# Security (Generate a strong random string for production)
# You can use: openssl rand -hex 32
SECRET_KEY=your-super-secret-key-change-me

# Supabase (For Auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key

# API Settings
API_V1_STR=/api/v1
PROJECT_NAME="BCE Event Manager"

# Allowed CORS Origins (Comma separated)
CORS_ORIGINS=http://localhost:5173,https://your-domain.vercel.app
